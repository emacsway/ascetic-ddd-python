{% macro vo_imports(used_vos, package_prefix, with_exporters=false) %}
{% for vo in used_vos %}
{% if vo.import_path %}
from {{ vo.import_path }} import {{ vo.class_name }}
{% if with_exporters and vo is composite_vo %}
from {{ vo.import_path }}_exporter import {{ vo.class_name }}Exporter
{% endif %}
{% else %}
from {{ package_prefix }}.values import {{ vo.class_name }}
{% if with_exporters and vo is composite_vo %}
from {{ package_prefix }}.values import {{ vo.class_name }}Exporter
{% endif %}
{% endif %}
{% endfor %}
{% endmacro %}
